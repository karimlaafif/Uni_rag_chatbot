# ── Environnement Python ─────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── Variables d'environnement (secrets) ──────────────────────────────────
.env
.env.local
.env.example

# ── Données brutes (trop lourdes / potentiellement sensibles) ────────────
# Les fichiers sont ingérés dans Qdrant — pas besoin de les versionner
data/scolarite/
data/bibliotheque/
data/residence/
data/sport/
data/raw/
# Exception : le fichier de test déjà présent reste versionné
!data/guide_etudiant_uiz_2024_2025.txt
!data/guide_etudiant_uiz_2024_2025

# ── Volumes Docker (données persistantes locales) ─────────────────────────
qdrant_data/
ollama_data/
redis_data/
postgres_data/

# ── Résultats de benchmarks ───────────────────────────────────────────────
benchmarks/results/*.csv
benchmarks/results/*.html

# ── Build Java / Maven ────────────────────────────────────────────────────
backend-jee/target/
backend-jee/.mvn/
!backend-jee/.mvn/wrapper/maven-wrapper.properties

# ── Clés privées RSA (NE JAMAIS committer en production) ─────────────────
backend-jee/src/main/resources/META-INF/resources/privateKey.pem

# ── Build frontend ────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/

# ── IDE ───────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
